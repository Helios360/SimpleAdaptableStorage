# Base app config
PORT=3000
HOST=0.0.0.0
NODE_ENV=dev
APP_URL=http://localhost:3000/

# DB Configuration
MYSQL_HOST=mysql
MYSQL_USER=mysql
MYSQL_DATABASE=simplepeoplestoring
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=password

# If your service is not gmail
#SMTP_HOST=
#SMTP_PORT=
#SMTP_USER=no-reply@cloud-campus.fr
#SMTP_PASS=

# Email API configs for Google Gmail api
SERVICE_CLIENT=515614327854687521468
SERVICE_CLIENT_SECRET=-----BEGIN PRIVATE KEY----- -----END PRIVATE KEY-----

# Backup system, the whole db and uploaded files can be backed up by a docker service
# built by the composer
APP_UPLOADS_DIR=/usr/src/app/uploads
APP_BASE_DIR=/usr/src/app

MYSQL_DATA_DIR=/srv/mysql
NAS_UPLOADS=/mnt/nas/cloudportail/simplepeoplestoring/uploads
NAS_BACKUPS=/mnt/nas/cloudportail/simplepeoplestoring/backups/mysql

# Misc
TOS_VERSION=0
JWT_SECRET=asecret
OPENAI_API_KEY=anapikey
TZ=Europe/Paris